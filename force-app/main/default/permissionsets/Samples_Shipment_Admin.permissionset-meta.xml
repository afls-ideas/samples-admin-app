<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Samples Shipment Admin</label>
    <description>Provides access to Samples Admin App tabs and Apex controllers</description>
    <hasActivationRequired>false</hasActivationRequired>
    <tabSettings>
        <tab>Samples_Admin</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Samples_Shipment_Creator</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>User_Inventory_Location_Creator</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <classAccesses>
        <apexClass>SamplesShipmentController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>UserInventoryLocationController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SourceLocationController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
